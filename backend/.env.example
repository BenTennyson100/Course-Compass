# Google OAuth — get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL (where to redirect after login)
FRONTEND_URL=http://localhost:5173

# MySQL connection string
# Format: mysql+pymysql://user:password@host/database_name
DATABASE_URL=mysql+pymysql://root:password@localhost/course_compass

# JWT secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
